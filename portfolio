def price_scaling(raw_prices_df):
    scaled_prices_df = raw_prices_df.copy()
    for i in raw_prices_df.columns[1:]:
          scaled_prices_df[i] = raw_prices_df[i]/raw_prices_df[i][0]
    return scaled_prices_df

def asset_allocation(df, weights, initial_investment):
    portfolio_df = df.copy()
    scaled_df = price_scaling(df)
    for i, stock in enumerate(scaled_df.columns[1:]):
        portfolio_df[stock] = scaled_df[stock] * weights[i] * initial_investment
    portfolio_df['Portfolio Value [INR]'] = portfolio_df[portfolio_df != 'Date'].sum(axis = 1, numeric_only = True)
    # Calculate the portfolio percentage daily return and replace NaNs with zeros
    portfolio_df['Portfolio Daily Return [%]'] = portfolio_df['Portfolio Value [INR]'].pct_change(1) * 100
    portfolio_df.replace(np.nan, 0, inplace = True)
    return portfolio_df

# ====================== VALUE AT RISK (VaR) FUNCTIONS ======================

def calculate_portfolio_returns(weights, returns_df, initial_investment=10_000_000):
    """Calculate daily portfolio returns and final value for given weights"""
    portfolio_df = asset_allocation(close_price_df, weights, initial_investment)
    daily_port_returns = portfolio_df['Portfolio Daily Return [%]'] / 100   # convert % to decimal
    return daily_port_returns.dropna(), portfolio_df['Portfolio Value [INR]'].iloc[-1]


def historical_var(portfolio_daily_returns, confidence_level=0.95, portfolio_value=10_000_000):
    """Historical Simulation VaR - uses actual historical returns distribution"""
    alpha = 1 - confidence_level
    var_return = np.percentile(portfolio_daily_returns, alpha * 100)   # e.g., 5th percentile for 95% VaR
    var_amount = -var_return * portfolio_value                         # positive loss amount
    return var_return, var_amount


def parametric_var(weights, returns_df, confidence_level=0.95, portfolio_value=10_000_000,
                   risk_free_rate=0.02, days=1):
    """Parametric (Variance-Covariance) VaR - assumes normal distribution"""
    # Daily portfolio return stats
    port_mean = np.sum(weights * returns_df.mean())          # daily mean return
    cov_matrix = returns_df.cov()
    port_std = np.sqrt(np.dot(weights.T, np.dot(cov_matrix, weights)))   # daily volatility

    # Scale to desired horizon (default 1 day)
    z_score = stats.norm.ppf(1 - confidence_level)           # e.g., -1.645 for 95%
    var_return = port_mean * days - z_score * port_std * np.sqrt(days)

    var_amount = -var_return * portfolio_value
    return var_return, var_amount, port_std


def monte_carlo_var(weights, returns_df, num_simulations=10000, confidence_level=0.95,
                    portfolio_value=10_000_000, time_horizon=1):
    """Monte Carlo VaR - generates simulated future returns"""
    mean_returns = returns_df.mean()
    cov_matrix = returns_df.cov()

    # Cholesky decomposition for correlated simulations
    L = np.linalg.cholesky(cov_matrix)

    # Simulate returns
    simulated_returns = np.zeros(num_simulations)
    for i in range(num_simulations):
        Z = np.random.normal(size=len(weights))
        daily_sim_returns = mean_returns + L @ Z
        simulated_returns[i] = np.dot(weights, daily_sim_returns) * time_horizon

    # VaR from simulated distribution
    alpha = 1 - confidence_level
    var_return = np.percentile(simulated_returns, alpha * 100)
    var_amount = -var_return * portfolio_value

    return var_return, var_amount, simulated_returns

def generate_portfolio_weights(n):
    weights = []
    for i in range(n):
        weights.append(random.random())

    # let's make the sum of all weights add up to 1
    weights = np.array(weights)/np.sum(weights)
    return weights

